<Window x:Class="Prototip.Views.SalesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Prototip.Views"
        mc:Ignorable="d"
        Title="SalesWindow" Height="700" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Список продаж" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
        
        <ListBox x:Name="LstSales" Grid.Row="1" Margin="0,0,0,10" 
                 SelectionChanged="LstSales_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel>
                                <TextBlock FontWeight="Bold" FontSize="14">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Продажа №{0}">
                                            <Binding Path="Id"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Text="{Binding SaleDate, StringFormat=Дата: dd.MM.yyyy HH:mm}" 
                                           FontSize="11" Foreground="Gray"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Column="1" Text="{Binding PaymentMethod}" 
                                       Foreground="Blue" VerticalAlignment="Center"/>
                            
                            <TextBlock Grid.Column="2" Text="{Binding TotalAmount, StringFormat={}{0:C}}" 
                                       Foreground="Green" FontWeight="Bold" VerticalAlignment="Center"/>
                            
                            <Button Grid.Column="3" Content="Удалить" Width="70" Height="25" 
                                    Click="BtnDeleteSale_Click" Tag="{Binding}" Background="LightCoral"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <!-- Форма создания продажи (остается без изменений) -->
        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="0,1,0,0" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="350">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="Сотрудник:" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbEmployee" Grid.Column="1" Margin="5" Height="30"
                              DisplayMemberPath="FullName" SelectedValuePath="Id"/>
                    
                    <TextBlock Text="Дата:" Grid.Row="1" VerticalAlignment="Center"/>
                    <DatePicker x:Name="DpDate" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <TextBlock Text="Оплата:" Grid.Row="2" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbPayment" Grid.Row="2" Grid.Column="1" Margin="5" Height="30">
                        <ComboBoxItem Content="Наличные"/>
                        <ComboBoxItem Content="Карта"/>
                        <ComboBoxItem Content="Смешанный"/>
                    </ComboBox>
                    
                    <TextBlock Text="Добавить товар:" Grid.Row="3" VerticalAlignment="Center"/>
                    <Grid Grid.Row="3" Grid.Column="1" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        
                        <ComboBox x:Name="CmbProduct" Grid.Column="0" Height="30"
                                  DisplayMemberPath="Name" SelectedValuePath="Id"/>
                        <TextBox x:Name="TxtQuantity" Grid.Column="1" Margin="5,0" Height="30" Text="1"/>
                        <Button x:Name="BtnAddItem" Grid.Column="2" Content="Добавить" Height="30" 
                                Click="BtnAddItem_Click" Background="LightBlue"/>
                    </Grid>
                    
                    <!-- Список товаров в чеке -->
                    <ListBox x:Name="LstItems" Grid.Row="4" Grid.ColumnSpan="2" Height="150" Margin="5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock>
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="Товар №{0}">
                                                    <Binding Path="ProductId"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" Text="{Binding Quantity}" 
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Price, StringFormat={}{0:C}}" 
                                                   HorizontalAlignment="Right"/>
                                        <Button Grid.Column="3" Content="Удалить" Width="60" Height="25" 
                                                Click="BtnRemoveItem_Click" Tag="{Binding}" Background="LightCoral"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <!-- Итого -->
                    <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" 
                                HorizontalAlignment="Right" Margin="5">
                        <TextBlock Text="Итого:" VerticalAlignment="Center" Margin="0,0,10,0" 
                                   FontSize="14" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtTotal" FontWeight="Bold" FontSize="14" 
                                   VerticalAlignment="Center" Foreground="Green"/>
                    </StackPanel>
                    
                    <!-- Кнопки -->
                    <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" 
                                HorizontalAlignment="Right" Margin="5">
                        <Button x:Name="BtnSave" Content="Оформить продажу" Width="150" Height="35" 
                                Click="BtnSave_Click" Background="LightGreen" Margin="0,0,5,0"/>
                        <Button x:Name="BtnClear" Content="Очистить" Width="100" Height="35" 
                                Click="BtnClear_Click" Background="LightGray"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
