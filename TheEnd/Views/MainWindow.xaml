<Window x:Class="Prototip.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Prototip.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Учет розничного магазина" 
                   FontSize="28" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,30"/>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel HorizontalAlignment="Center">
                <Button Content="📁 Категории" Width="150" Height="80" 
                        Margin="10" FontSize="14" Background="LightBlue" Click="BtnCategories_Click"/>
                <Button Content="📦 Товары" Width="150" Height="80" 
                        Margin="10" FontSize="14" Background="LightGreen" Click="BtnProducts_Click"/>
                <Button Content="🏭 Поставщики" Width="150" Height="80" 
                        Margin="10" FontSize="14" Background="LightYellow" Click="BtnSuppliers_Click"/>
                <Button Content="🚚 Поставки" Width="150" Height="80" 
                        Margin="10" FontSize="14" Background="LightCoral" Click="BtnDeliveries_Click"/>
                <Button Content="👥 Сотрудники" Width="150" Height="80" 
                        Margin="10" FontSize="14" Background="LightGray" Click="BtnEmployees_Click"/>
                <Button Content="💰 Продажи" Width="150" Height="80" 
                        Margin="10" FontSize="14" Background="LightPink" Click="BtnSales_Click"/>
                <Button Content="🚪 Выход" Width="150" Height="80" 
                        Margin="10" FontSize="14" Background="LightSalmon" Click="BtnExit_Click"/>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Window>
