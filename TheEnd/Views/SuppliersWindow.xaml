<Window x:Class="Prototip.Views.SuppliersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Prototip.Views"
        mc:Ignorable="d"
        Title="SuppliersWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Список поставщиков" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
        
        <ListBox x:Name="LstSuppliers" Grid.Row="1" Margin="0,0,0,10" 
                 SelectionChanged="LstSuppliers_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Grid.Column="1" Text="{Binding Phone}" Foreground="Gray"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="0,1,0,0" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="Название:" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtName" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <TextBlock Text="Контакт:" Grid.Row="1" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtContact" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <TextBlock Text="Телефон:" Grid.Row="2" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtPhone" Grid.Row="2" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <TextBlock Text="Адрес:" Grid.Row="3" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtAddress" Grid.Row="3" Grid.Column="1" Margin="5" Height="60" TextWrapping="Wrap"/>
                    
                    <TextBlock Text="ИНН:" Grid.Row="4" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtInn" Grid.Row="4" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" 
                                HorizontalAlignment="Right" Margin="5">
                        <Button x:Name="BtnAdd" Content="Добавить" Width="100" Height="35" 
                                Click="BtnAdd_Click" Background="LightGreen" Margin="0,0,5,0"/>
                        <Button x:Name="BtnUpdate" Content="Изменить" Width="100" Height="35" 
                                Click="BtnUpdate_Click" Background="LightBlue" Margin="0,0,5,0"/>
                        <Button x:Name="BtnDelete" Content="Удалить" Width="100" Height="35" 
                                Click="BtnDelete_Click" Background="LightCoral"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
