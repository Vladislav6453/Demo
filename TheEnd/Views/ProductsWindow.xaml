<Window x:Class="Prototip.Views.ProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Prototip.Views"
        mc:Ignorable="d"
        Title="ProductsWindow" Height="700" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Список товаров" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
        
        <ListBox MinHeight="200" x:Name="LstProducts" ItemsSource="{Binding Products}" Grid.Row="1" Margin="0,0,0,10" 
                 SelectionChanged="LstProducts_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding Barcode}" FontSize="10" Foreground="Gray"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Розница:" FontSize="10"/>
                                <TextBlock Text="{Binding RetailPrice, StringFormat={}{0:C}}" 
                                           Foreground="Green" FontWeight="Bold"/>
                                <TextBlock Text="Закуп:" FontSize="10"/>
                                <TextBlock Text="{Binding PurchasePrice, StringFormat={}{0:C}}" Foreground="Gray"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Остаток:" FontSize="10"/>
                                <TextBlock Text="{Binding Quantity}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding Unit}" FontSize="10"/>
                                <TextBlock Text="{Binding MinQuantity, StringFormat=Мин: {0}}" 
                                           Foreground="Red" FontSize="10"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="0,1,0,0" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="350">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="Название:" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtName" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <TextBlock Text="Штрихкод:" Grid.Row="1" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtBarcode" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <TextBlock Text="Категория:" Grid.Row="2" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbCategory" Grid.Row="2" Grid.Column="1" Margin="5" Height="30"
                              DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    
                    <TextBlock Text="Закуп. цена:" Grid.Row="3" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtPurchasePrice" Grid.Row="3" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <TextBlock Text="Розн. цена:" Grid.Row="4" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtRetailPrice" Grid.Row="4" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <TextBlock Text="Количество:" Grid.Row="5" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtQuantity" Grid.Row="5" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <TextBlock Text="Ед. изм.:" Grid.Row="6" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbUnit" Grid.Row="6" Grid.Column="1" Margin="5" Height="30">
                        <ComboBoxItem Content="шт"/>
                        <ComboBoxItem Content="кг"/>
                        <ComboBoxItem Content="л"/>
                        <ComboBoxItem Content="уп"/>
                    </ComboBox>
                    
                    <TextBlock Text="Мин. запас:" Grid.Row="7" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtMinQuantity" Grid.Row="7" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <StackPanel Grid.Row="8" Grid.ColumnSpan="2" Orientation="Horizontal" 
                                HorizontalAlignment="Right" Margin="5">
                        <Button x:Name="BtnAdd" Content="Добавить" Width="100" Height="35" 
                                Click="BtnAdd_Click" Background="LightGreen" Margin="0,0,5,0"/>
                        <Button x:Name="BtnUpdate" Content="Изменить" Width="100" Height="35" 
                                Click="BtnUpdate_Click" Background="LightBlue" Margin="0,0,5,0"/>
                        <Button x:Name="BtnDelete" Content="Удалить" Width="100" Height="35" 
                                Click="BtnDelete_Click" Background="LightCoral"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
