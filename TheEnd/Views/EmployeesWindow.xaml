<Window x:Class="Prototip.Views.EmployeesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Prototip.Views"
        mc:Ignorable="d"
        Title="EmployeesWindow" Height="700" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Список сотрудников" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
        
        <ListBox x:Name="LstEmployees" Grid.Row="1" Margin="0,0,0,10" 
                 SelectionChanged="LstEmployees_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel>
                                <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding Position}" FontSize="10" Foreground="Gray"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Column="1" Text="{Binding Phone}" Foreground="Gray"/>
                            
                            <TextBlock Grid.Column="2" Text="{Binding Role}" Foreground="Blue"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="0,1,0,0" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="ФИО:" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtFullName" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <TextBlock Text="Должность:" Grid.Row="1" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtPosition" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <TextBlock Text="Телефон:" Grid.Row="2" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtPhone" Grid.Row="2" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <TextBlock Text="Дата приема:" Grid.Row="3" VerticalAlignment="Center"/>
                    <DatePicker x:Name="DpHireDate" Grid.Row="3" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <TextBlock Text="Логин:" Grid.Row="4" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtLogin" Grid.Row="4" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <TextBlock Text="Пароль:" Grid.Row="5" VerticalAlignment="Center"/>
                    <TextBox x:Name="TxtPassword" Grid.Row="5" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <TextBlock Text="Роль:" Grid.Row="6" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbRole" Grid.Row="6" Grid.Column="1" Margin="5" Height="30">
                        <ComboBoxItem Content="Admin" Tag="Admin"/>
                        <ComboBoxItem Content="Cashier" Tag="Cashier" IsSelected="True"/>
                    </ComboBox>
                    
                    <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" 
                                HorizontalAlignment="Right" Margin="5">
                        <Button x:Name="BtnAdd" Content="Добавить" Width="100" Height="35" 
                                Click="BtnAdd_Click" Background="LightGreen" Margin="0,0,5,0"/>
                        <Button x:Name="BtnUpdate" Content="Изменить" Width="100" Height="35" 
                                Click="BtnUpdate_Click" Background="LightBlue" Margin="0,0,5,0"/>
                        <Button x:Name="BtnDelete" Content="Удалить" Width="100" Height="35" 
                                Click="BtnDelete_Click" Background="LightCoral"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
