<Window x:Class="Prototip.Views.DeliveriesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Prototip.Views"
        mc:Ignorable="d"
        Title="DeliveriesWindow" Height="700" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Список поставок" FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
        
        <ListBox x:Name="LstDeliveries" Grid.Row="1" Margin="0,0,0,10" 
                 SelectionChanged="LstDeliveries_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel>
                                <TextBlock Text="{Binding SupplierName}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="{Binding DeliveryDate, StringFormat=dd.MM.yyyy}" FontSize="10" Foreground="Gray"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat={}{0:C}}" 
                                       Foreground="Green" FontWeight="Bold"/>
                            
                            <Button Grid.Column="2" Content="Удалить" Width="70" Height="25" 
                                    Click="BtnDeleteDelivery_Click" Tag="{Binding}" Background="LightCoral"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="0,1,0,0" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="350">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="Поставщик:" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbSupplier" Grid.Column="1" Margin="5" Height="30"
                              DisplayMemberPath="Name" SelectedValuePath="Id"/>
                    
                    <TextBlock Text="Дата:" Grid.Row="1" VerticalAlignment="Center"/>
                    <DatePicker x:Name="DpDate" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>
                    
                    <TextBlock Text="Товары:" Grid.Row="2" VerticalAlignment="Center"/>
                    <Grid Grid.Row="2" Grid.Column="1" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        
                        <ComboBox x:Name="CmbProduct" Grid.Column="0" Height="30"
                                  DisplayMemberPath="Name" SelectedValuePath="Id"/>
                        <TextBox x:Name="TxtQuantity" Grid.Column="1" Margin="5,0" Height="30" Text="1"/>
                        <TextBox x:Name="TxtPrice" Grid.Column="2" Margin="5,0" Height="30"/>
                        <Button x:Name="BtnAddItem" Grid.Column="3" Content="Добавить" Height="30" 
                                Click="BtnAddItem_Click" Background="LightBlue"/>
                    </Grid>
                    
                    <ListBox x:Name="LstItems" Grid.Row="3" Grid.ColumnSpan="2" Height="150" Margin="5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Text="{Binding ProductName}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Quantity}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding PurchasePrice, StringFormat={}{0:C}}" HorizontalAlignment="Right"/>
                                        <Button Grid.Column="3" Content="Удалить" Width="60" Height="25" 
                                                Click="BtnRemoveItem_Click" Tag="{Binding}" Background="LightCoral"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" 
                                HorizontalAlignment="Right" Margin="5">
                        <TextBlock Text="Итого:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="TxtTotal" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" 
                                HorizontalAlignment="Right" Margin="5">
                        <Button x:Name="BtnSave" Content="Сохранить поставку" Width="150" Height="35" 
                                Click="BtnSave_Click" Background="LightGreen" Margin="0,0,5,0"/>
                        <Button x:Name="BtnClear" Content="Очистить" Width="100" Height="35" 
                                Click="BtnClear_Click" Background="LightGray"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
